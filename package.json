{
  "name": "openclaw-channel-telegram-userbot",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin — Telegram userbot via MTProto (GramJS)",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "auth": "bun run src/auth.ts",
    "dev": "bun run src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": ["openclaw", "telegram", "userbot", "mtproto", "gramjs", "channel", "plugin"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/overpod/openclaw-channel-telegram-userbot"
  },
  "author": "overpod",
  "openclaw": {
    "type": "channel",
    "id": "telegram-userbot"
  },
  "dependencies": {
    "node-machine-id": "^1.1.12",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
